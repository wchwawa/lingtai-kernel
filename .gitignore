.worktrees/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build / packaging
build/
dist/

# Rust sidecar — cargo build artifacts and the binary that setup.py drops
# into the package tree at build time. Both are reproducible from the
# crate sources under experimental/lingtai-search-sidecar/.
experimental/lingtai-search-sidecar/target/
src/lingtai/bin/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Local caches
.cache/
.library/

# Environments
.env
.venv/
venv/

# Local agent/work-session scratch. These directories often hold private
# transcripts, PR explainers, generated audits, or exploratory outputs. Keep PR
# explainers local by default; only long-lived docs, release materials, or
# reports with an explicit durable purpose should be force-added with rationale.
reports/
tmp/

# Local discussion drafts / architecture scratch. These are working notes, not
# durable repo docs; publish polished outcomes under docs/ or the relevant
# package/anatomy files instead.
discussions/

# Local resolver lockfiles may appear during experiments; pyproject.toml is the
# packaging source of truth for this repo.
uv.lock
