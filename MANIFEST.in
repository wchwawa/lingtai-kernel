# Include the Rust sidecar crate sources in the sdist so source-only
# installs can rebuild the native backend via ``setup.py``. Wheels do
# not need these files — they ship the pre-built binary under
# ``src/lingtai/bin/`` via ``[tool.setuptools.package-data]``.
graft crates/lingtai-search-sidecar/src
include crates/lingtai-search-sidecar/Cargo.toml
include crates/lingtai-search-sidecar/Cargo.lock
include crates/lingtai-search-sidecar/README.md

# Exclude transient cargo build artifacts so they don't bloat the sdist.
prune crates/lingtai-search-sidecar/target

# The wheel-bundled binary at src/lingtai/bin/ is reproducible from the
# crate sources above — keep it out of the sdist so source releases stay
# source-only. setup.py rebuilds it when the sdist is unpacked and built
# into a wheel.
exclude src/lingtai/bin/*
exclude src/lingtai/bin/__init__.py
prune src/lingtai/bin

# Top-level packaging shim and license live at the repo root.
include setup.py
include MANIFEST.in
include LICENSE
include NOTICE
include README.md
